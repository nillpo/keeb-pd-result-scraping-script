{
  "name": "KEEB_PD Result Scraper",
  "build": {
    "dockerfile": "./Dockerfile"
  },
  "features": {
    "ghcr.io/devcontainers/features/github-cli:latest": {}
  },
  "mounts": [
    "source=keeb-pd-claude-config-${devcontainerId},target=/home/vscode/.claude,type=volume",
    "source=keeb-pd-claude-bashhistory-${devcontainerId},target=/commandhistory,type=volume",
    // ホスト側のghの認証情報を使いたい場合
    // "source=${localEnv:HOME}${localEnv:USERPROFILE}/.config/gh,target=/home/vscode/.config/gh,type=bind"
    "source=keeb-pd-claude-gh-${devcontainerId},target=/home/vscode/.config/gh,type=volume"
  ],
  "remoteUser": "vscode",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces,type=bind",
  "workspaceFolder": "/workspaces",
  "postCreateCommand": "sh .devcontainer/post-create.sh"
}
